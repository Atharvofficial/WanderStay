<script>
  let navCollapseButton = document.querySelector(".navbar-toggler");
  let collapseList = document.querySelector(".navbar-collapse");
  let searchForm = document.querySelector(".d-flex-custom");
  navCollapseButton.addEventListener("click", ()=>{
    if(navCollapseButton.classList.contains("collapsed")){
      collapseList.style.border = "none";
      searchForm.style.display = "flex";
    }else{
      collapseList.style.border = "1px solid rgba(0, 0, 0, 0.3)";
      searchForm.style.display = "none";
    }
  })
</script>