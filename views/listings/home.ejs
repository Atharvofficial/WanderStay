<% layout("/templates/boilerplate.ejs") -%>

<body>
    <div class="container mb-4">
        <div class="filters-main-container">
            <div class="filters overflow-x-auto">
                <div class="filter">
                    <i class="fa-solid fa-fire"></i>
                    <p>Trending</p>
                </div>
                <div class="filter">
                    <i class="fa-solid fa-bed"></i>
                    <p>Rooms</p>
                </div>
                <div class="filter">
                    <i class="fa-solid fa-mountain-city"></i>
                    <p>Iconic Cities</p>
                </div>
                <div class="filter">
                    <i class="fa-solid fa-mountain"></i>
                    <p>Mountains</p>
                </div>
                <div class="filter">
                    <i class="fa-brands fa-fort-awesome"></i>
                    <p>Castles</p>
                </div>
                <div class="filter">
                    <i class="fa-solid fa-person-swimming"></i>
                    <p>Amazing Pools</p>
                </div>
                <div class="filter">
                    <i class="fa-solid fa-campground"></i>
                    <p>Camping</p>
                </div>
                <div class="filter">
                    <i class="fa-solid fa-cow"></i>
                    <p>Farms</p>
                </div>
                <div class="filter">
                    <i class="fa-solid fa-snowflake"></i>
                    <p>Arctic</p>
                </div>
                <div class="filter">
                    <i class="fa-solid fa-igloo"></i>
                    <p>Domes</p>
                </div>
                <div class="filter">
                    <i class="fa-solid fa-sailboat"></i>
                    <p>Boats</p>
                </div>

            </div>
            <div class="tax-toggle-wrapper">
                <div class="form-switch tax-switch">
                    <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
                    <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
                </div>
            </div>

        </div>

    </div>


    <div class="card-container container-fluid">
        <div class="row row-cols-xl-4 row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-3">
            <% for(const listing of data) { %>
            <a href="/listings/<%= listing._id %>" class="card-link">
                <div class="col">
                    <div class="card">
                        <img src="<%= listing.image.url %>" class="card-img-top" style="height: 20rem;" alt="...">
                        <div class="card-img-overlay">

                        </div>
                        <div class="card-body">
                            <p class="card-text">
                                <b><%= listing.title %> </b><br>
                                &#8377; <span class="price"
                                    data-originalprice="<%= listing.price%>"><%= listing.price.toLocaleString("en-IN") %></span>
                                / night &nbsp; <i class="gst">+18% GST</i>
                            </p>
                        </div>
                    </div>
                </div>
            </a>



            <% } %>
        </div>
    </div>





    <script>
        let input = document.querySelector(".form-check-input");
        let gstLines = document.querySelectorAll(".gst");
        let prices = document.querySelectorAll(".price");
        input.addEventListener("click", () => {

            for (gstLine of gstLines) {
                if (gstLine.style.display != "none") {
                    gstLine.style.display = "none";
                } else {
                    gstLine.style.display = "inline";
                }
            }

            if (input.checked) {
                for (price of prices) {
                    let currPrice = Number(price.getAttribute("data-originalprice"));
                    let newPrice = currPrice * 18 / 100 + currPrice;
                    price.innerText = newPrice.toLocaleString("en-IN");
                }
            } else {
                for (price of prices) {
                    let currPrice = Number(price.getAttribute("data-originalprice"));
                    let newPrice = currPrice;
                    price.innerText = newPrice.toLocaleString("en-IN");
                }
            }


        })

        const filters = document.querySelector(".filters");

        filters.addEventListener("wheel", (e) => {
            if (e.deltaY !== 0) {
                e.preventDefault();
                filters.scrollLeft += e.deltaY;
            }
        });
    </script>


</body>
