<% layout("/templates/boilerplate.ejs") -%>

<body>
    <script>
        const mapToken = "<%= mapToken %>";
        const coordinates = <%-JSON.stringify(listing.geometry.coordinates) %> ;
        const listingLocation = <%-JSON.stringify(listing.location) %> ;
    </script>
    <div class="row">
        <div class="col-6 offset-3">
            <h1><%= listing.title %></h1>
            <div class="listing-card">
                <img src="<%= listing.image.url %>" class="card-img-top card-image" alt="...">
                <br>
                <div class="card-body">
                    <p class="card-text">
                        <h6><i>Owned By <%= listing.owner.username %></i></h6>
                        <h5><%= listing.description %> </h5>
                        <h5>&#8377; <%= listing.price.toLocaleString("en-IN")%> / night &nbsp; &nbsp;<i>+18% GST</i></h5>
                        <h5><%= listing.location %> </h5>
                        <h5><%= listing.country %></h5>
                    </p>
                    <% if (currUser) { %>
                    <% if (listing.owner._id.toString() === currUser._id.toString()) { %>
                    <div class="row">
                         <div class="col-3 card-btn">
                                <form action="/listings/<%= listing._id %>/edit" method="get">
                                     <button class="btn edit-btn">Edit</button>
                                </form>
                                <form action="/listings/<%= listing._id %>?_method=DELETE" method="post">
                                    <button class="btn btn-dark del-btn">Delete</button>
                                </form>
                        </div>       
                    </div>

                    <% } %>
                    <% } %>

                </div>
            </div>
            <hr>
        </div>


        <div class="col-6 offset-3 mb-3">
            <div class="div">
                <h4>Where You'll Be</h4>
            </div>
            <div id="map" style="width: 100%; height: 40vh; border-radius: 10px;">
            </div>
            <hr>
        </div>


        <div class="col-6 offset-3 mb-3">

            <% if (currUser) { %>
            <h4>Leave a review</h4>
            <br>
            <form action="/listings/<%= listing._id %>/reviews" method="post" novalidate class="needs-validation">

                <fieldset class="starability-slot">
                    <h5>Rating</h5>
                    <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked
                        aria-label="No rating." />
                    <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                    <label for="first-rate1" title="Terrible">1 star</label>
                    <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                    <label for="first-rate2" title="Not good">2 stars</label>
                    <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                    <label for="first-rate3" title="Average">3 stars</label>
                    <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                    <label for="first-rate4" title="Very good">4 stars</label>
                    <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                    <label for="first-rate5" title="Amazing">5 stars</label>
                </fieldset>

                <br><br>
                <label for="comment" class="form-label">Comment</label>
                <div class="wrapper">
                    <textarea name="review[comment]" id="comment" required class="form-control" rows="5"></textarea>
                    <div class="invalid-feedback">Please Enter Comment</div>
                    <div class="valid-feedback">Looks Good</div>
                    <br>
                </div>
                <button class="btn btn-outline-dark">Submit</button>
            </form>
            <hr>
            <% } %>

            <% if (listing.reviews.length>0) { %>
            <h4>Reviews</h4>
            <br>
            <div class="row">
                <% for(const review of listing.reviews) { %>
                <div class="col-6">
                    <div class="card review-card">
                        <div class="card-body">
                            <h5 class="card-title"><%= review.author.username %></h5>
                            <p class="card-text starability-result" data-rating="<%= review.rating %>"></p>
                            <p class="card-text"><b><%= review.comment%></b></p>
                            <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                                method="post">
                                <% if (currUser) { %>
                                <% if (review.author._id.toString() === currUser._id.toString()) { %>
                                <button class="btn btn-danger">Delete</button>
                                <% } %>
                                <% } %>


                            </form>
                        </div>
                    </div>
                </div>
                <% } %>

            </div>
            <% } %>

        </div>
    </div>

    <script src="/js/map.js"></script>
</body>
